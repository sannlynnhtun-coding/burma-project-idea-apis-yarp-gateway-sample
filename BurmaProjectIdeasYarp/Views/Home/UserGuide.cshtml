@{
    ViewData["Title"] = "User Guide";
}

<div class="max-w-4xl mx-auto space-y-12">
    <div class="flex flex-col gap-2 border-b border-border pb-8">
        <h1 class="text-4xl font-bold tracking-tight">User Guide</h1>
        <p class="text-xl text-muted-foreground italic">Mastering the Burma Project Ideas YARP Gateway.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight text-primary italic">Getting Started</h2>
        <div class="rounded-xl border border-border bg-card p-6 shadow-sm space-y-4">
            <p>Welcome to your new YARP Gateway management system. This application allows you to dynamically configure routing rules and backend clusters without restarting the service.</p>
            <div class="grid gap-4 md:grid-cols-2">
                <div class="space-y-2">
                    <h3 class="font-medium">LiteDB Storage</h3>
                    <p class="text-sm text-muted-foreground">All configurations are stored in <code>yarp_config.db</code>. This ensures high performance and persistence.</p>
                </div>
                <div class="space-y-2">
                    <h3 class="font-medium">Dynamic Reload</h3>
                    <p class="text-sm text-muted-foreground">Changes made in the UI are applied instantly to the YARP proxy engine.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight text-primary italic">Managing Routes</h2>
        <div class="space-y-4">
            <div class="p-4 border-l-4 border-primary bg-muted/30 rounded-r-lg">
                <p class="text-sm">Routes define how incoming requests are matched and which cluster they should be forwarded to.</p>
            </div>
            <ul class="list-disc list-inside space-y-2 text-sm text-muted-foreground ml-4">
                <li><span class="font-medium text-foreground italic">Route ID:</span> A unique identifier for the routing rule.</li>
                <li><span class="font-medium text-foreground italic">Path Match:</span> The URL pattern to match. Example: <code>/api/calendar/{**catch-all}</code></li>
                <li><span class="font-medium text-foreground italic">Cluster:</span> The backend group that will handle the request.</li>
            </ul>
        </div>
    </section>

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight text-primary italic">Managing Clusters</h2>
        <div class="rounded-xl border border-border bg-card p-6 shadow-sm space-y-6">
            <p class="text-sm text-muted-foreground">Clusters are groups of one or more destination servers that provide the actual API services.</p>
            <div class="space-y-4 text-sm">
                <div class="flex items-start gap-4">
                    <div class="bg-primary/10 text-primary p-2 rounded-full mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                    </div>
                    <div>
                        <h4 class="font-medium italic">Destinations</h4>
                        <p class="text-muted-foreground">List server addresses (e.g., <code>http://localhost:5001</code>). Multiple addresses allow for load balancing.</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="bg-blue-500/10 text-blue-500 p-2 rounded-full mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    </div>
                    <div>
                        <h4 class="font-medium italic">Load Balancing</h4>
                        <p class="text-muted-foreground">Choose from Round Robin, Random, Least Requests, etc., to distribute traffic.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight text-primary italic">Seeding Data</h2>
        <div class="p-6 rounded-xl border border-dashed border-border flex flex-col items-center gap-4 text-center">
            <div class="bg-muted p-4 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </div>
            <div class="space-y-2">
                <h3 class="font-semibold">Automatic Import</h3>
                <p class="text-sm text-muted-foreground max-w-sm">The system automatically imports existing JSON configurations from <code>api-*-routes.json</code> files if they are enabled in <code>api-settings.json</code> and not already in the database.</p>
            </div>
        </div>
    </section>
</div>
